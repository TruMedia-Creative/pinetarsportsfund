{
  "name": "pinetarsportsfund",
  "private": true,
  "version": "1.0.0",
  "packageManager": "pnpm@10.0.0",
  "scripts": {
    "dev": "pnpm --filter @pinetarsf/site dev",
    "dev:site": "pnpm --filter @pinetarsf/site dev",
    "dev:dashboard": "pnpm --filter @pinetarsf/dashboard dev",
    "build": "pnpm -r build",
    "build:site": "pnpm --filter @pinetarsf/site build",
    "build:dashboard": "pnpm --filter @pinetarsf/dashboard build",
    "test": "pnpm -r test",
    "lint": "pnpm -r lint",
    "typecheck": "pnpm -r typecheck",
    "setup": "corepack enable && pnpm install --frozen-lockfile",
    "check": "pnpm lint && pnpm typecheck && pnpm build"
  }
}
