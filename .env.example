# Site
SITE_URL=https://pinetarsportsfund.com

# ── Nuxt Studio (content editor) ──────────────────────────────
# GitHub Personal Access Token with repo write access.
# Studio uses this to push content changes to the repository.
STUDIO_GITHUB_TOKEN=ghp_your-token-here

# Admin credentials for the /admin login page.
# Nuxt auto-maps NUXT_* env vars into runtimeConfig at runtime.
NUXT_ADMIN_USERNAME=admin
NUXT_ADMIN_PASSWORD=change-me-before-production
